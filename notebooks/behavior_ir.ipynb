   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "---\n",
    "## Section 3: Noise Reducer & Behavior Motif Detector\n",
    "\n",
    "A **behavior motif** is a higher-level behavioral pattern derived from a sequence or co-occurrence of low-level events.\n",
    "\n",
    "| Motif | Detection rule |\n",
    "|---|---|\n",
    "| `persistence_registry_runkey` | reg_write to Run/RunOnce key |\n",
    "| `process_injection` | any of WriteProcessMemory / VirtualAllocEx / CreateRemoteThread |\n",
    "| `file_dropper` | file_write of an executable extension |\n",
    "| `dns_c2_beacon` | >= 1 dns_query event |\n",
    "| `http_c2` | http_request event present |\n",
    "| `keylogger_hook` | SetWindowsHookEx / GetAsyncKeyState |\n",
    "| `lateral_movement` | tcp_connect + process_create |\n",
    "| `credential_access` | Reads from LSASS path or SAM registry hive |"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# -----------------------------------------------------------\n",
    "# SECTION 3: Noise Reducer & Behavior Motif Detector\n",
    "# -----------------------------------------------------------\n",
    "\n",
    "def deduplicate_events(events: List[Dict[str, Any]]) -> List[Dict[str, Any]]:\n",
    "    \"\"\"\n",
    "    Remove exact duplicate events (same type + value).\n",
    "    Preserves insertion order (first occurrence kept).\n",
    "    \"\"\"\n",
    "    seen = set()\n",
    "    unique: List[Dict[str, Any]] = []\n",
    "    for e in events:\n",
    "        key = (e[\"type\"], e[\"value\"])\n",
    "        if key not in seen:\n",
    "            seen.add(key)\n",
    "            unique.append(e)\n",
    "    return unique\n",
    "\n",
    "\n",
    "def detect_motifs(events: List[Dict[str, Any]]) -> List[Dict[str, Any]]:\n",
    "    \"\"\"\n",
    "    Collapse de-duplicated events into scored behavior motifs.\n",
    "\n",
    "    Returns a list of motif dicts:\n",
    "        {\"type\": str, \"evidence\": [str, ...], \"score\": float}\n",
    "    \"\"\"\n",
    "    by_type: Dict[str, List[str]] = defaultdict(list)\n",
    "    for e in events:\n",
    "        by_type[e[\"type\"]].append(e[\"value\"])\n",
    "\n",
    "    motifs: List[Dict[str, Any]] = []\n",
    "\n",
    "    # ---- Persistence via Run key ----\n",
    "    run_keys = [\n",
    "        v for v in by_type[\"reg_write\"]\n",
    "        if any(pat.search(v) for pat in RUN_KEY_PATTERNS)\n",
    "    ]\n",
    "    if run_keys:\n",
    "        motifs.append({\n",
    "            \"type\": \"persistence_registry_runkey\",\n",
    "            \"evidence\": run_keys[:5],\n",
    "            \"score\": min(0.5 + 0.1 * len(run_keys), 1.0),\n",
    "        })\n",
    "\n",
    "    # ---- Process injection ----\n",
    "    inj_apis = [v for v in by_type[\"suspicious_api_call\"] if v in INJECTION_APIS]\n",
    "    if inj_apis:\n",
    "        score = min(0.3 * len(set(inj_apis)), 1.0)\n",
    "        motifs.append({\n",
    "            \"type\": \"process_injection\",\n",
    "            \"evidence\": list(set(inj_apis)),\n",
    "            \"score\": round(score, 2),\n",
    "        })\n",
    "\n",
    "    # ---- File dropper ----\n",
    "    dropped = [\n",
    "        v for v in by_type[\"file_write\"]\n",
    "        if Path(v).suffix.lower() in EXECUTABLE_EXTS\n",
    "    ]\n",
    "    if dropped:\n",
    "        motifs.append({\n",
    "            \"type\": \"file_dropper\",\n",
    "            \"evidence\": dropped[:5],\n",
    "            \"score\": min(0.4 + 0.1 * len(dropped), 1.0),\n",
    "        })\n",
    "\n",
    "    # ---- DNS C2 beacon ----\n",
    "    dns_queries = by_type[\"dns_query\"]\n",
    "    if dns_queries:\n",
    "        motifs.append({\n",
    "            \"type\": \"dns_c2_beacon\",\n",
    "            \"evidence\": [f\"domain: {d}\" for d in dns_queries[:5]],\n",
    "            \"score\": min(0.3 + 0.05 * len(dns_queries), 1.0),\n",
    "        })\n",
    "\n",
    "    # ---- HTTP C2 ----\n",
    "    http_reqs = by_type[\"http_request\"]\n",
    "    if http_reqs:\n",
    "        motifs.append({\n",
    "            \"type\": \"http_c2\",\n",
    "            \"evidence\": http_reqs[:5],\n",
    "            \"score\": min(0.4 + 0.05 * len(http_reqs), 1.0),\n",
    "        })\n",
    "\n",
    "    # ---- Keylogger / hook ----\n",
    "    hook_apis = [v for v in by_type[\"suspicious_api_call\"] if v in HOOK_APIS]\n",
    "    if hook_apis:\n",
    "        motifs.append({\n",
    "            \"type\": \"keylogger_hook\",\n",
    "            \"evidence\": list(set(hook_apis)),\n",
    "            \"score\": 0.75,\n",
    "        })\n",
    "\n",
    "    # ---- Lateral movement: tcp_connect + process_create ----\n",
    "    if by_type[\"tcp_connect\"] and by_type[\"process_create\"]:\n",
    "        motifs.append({\n",
    "            \"type\": \"lateral_movement\",\n",
    "            \"evidence\": (\n",
    "                [f\"tcp: {v}\" for v in by_type[\"tcp_connect\"][:3]]\n",
    "                + [f\"proc: {v[:60]}\" for v in by_type[\"process_create\"][:2]]\n",
    "            ),\n",
    "            \"score\": 0.65,\n",
    "        })\n",
    "\n",
    "    # ---- Credential access: LSASS / SAM paths ----\n",
    "    cred_paths = [\n",
    "        v for v in (by_type[\"file_read\"] + by_type[\"reg_read\"])\n",
    "        if re.search(r\"(lsass|sam|security|ntds\\.dit|credential)\", v, re.IGNORECASE)\n",
    "    ]\n",
    "    if cred_paths:\n",
    "        motifs.append({\n",
    "            \"type\": \"credential_access\",\n",
    "            \"evidence\": cred_paths[:5],\n",
    "            \"score\": 0.80,\n",
    "        })\n",
    "\n",
    "    # ---- Registry-heavy activity ----\n",
    "    if len(by_type[\"reg_write\"]) >= 10:\n",
    "        motifs.append({\n",
    "            \"type\": \"heavy_registry_activity\",\n",
    "            \"evidence\": [f\"{len(by_type['reg_write'])} registry writes\"],\n",
    "            \"score\": round(min(0.2 + 0.01 * len(by_type[\"reg_write\"]), 0.7), 2),\n",
    "        })\n",
    "\n",
    "    # Sort motifs by score descending\n",
    "    motifs.sort(key=lambda m: m[\"score\"], reverse=True)\n",
    "    return motifs\n",
    "\n",
    "\n",
    "# Smoke-test\n",
    "if json_files:\n",
    "    evts      = normalize_events(sample)\n",
    "    deduped   = deduplicate_events(evts)\n",
    "    motifs    = detect_motifs(deduped)\n",
    "    print(f\"Events: {len(evts)}  ->  after dedup: {len(deduped)}\")\n",
    "    print(f\"\\nDetected motifs ({len(motifs)}):\")\n",
    "    for m in motifs:\n",
    "        print(f\"  [{m['score']:.2f}] {m['type']}  evidence={m['evidence'][:2]}\")"
   ]
  },
