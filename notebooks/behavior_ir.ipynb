   "source": [
    "---\n",
    "## Section 4: IR Builder\n",
    "\n",
    "Assemble the final compact IR object for each report, including:\n",
    "- `behaviors`: scored motif list\n",
    "- `iocs`: concrete Indicators of Compromise\n",
    "- `process_graph`: lightweight process tree (nodes + edges)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# -----------------------------------------------------------\n",
    "# SECTION 4: IR Builder\n",
    "# -----------------------------------------------------------\n",
    "\n",
    "def build_process_graph(report: dict) -> Dict[str, Any]:\n",
    "    \"\"\"\n",
    "    Build a lightweight process graph from the behavior.processes section.\n",
    "    Nodes are processes; edges represent parent->child spawn.\n",
    "    \"\"\"\n",
    "    nodes: List[Dict[str, str]] = []\n",
    "    edges: List[Dict[str, str]] = []\n",
    "\n",
    "    processes = report.get(\"behavior\", {}).get(\"processes\", [])\n",
    "    pid_to_name: Dict[int, str] = {}\n",
    "\n",
    "    for proc in processes:\n",
    "        pid  = proc.get(\"pid\",  -1)\n",
    "        ppid = proc.get(\"ppid\", -1)\n",
    "        name = proc.get(\"process_name\") or proc.get(\"name\") or f\"pid_{pid}\"\n",
    "        pid_to_name[pid] = name\n",
    "        nodes.append({\"pid\": str(pid), \"name\": name})\n",
    "\n",
    "    seen_edges: set = set()\n",
    "    for proc in processes:\n",
    "        pid  = proc.get(\"pid\",  -1)\n",
    "        ppid = proc.get(\"ppid\", -1)\n",
    "        if ppid != -1 and ppid in pid_to_name:\n",
    "            edge_key = (str(ppid), str(pid))\n",
    "            if edge_key not in seen_edges:\n",
    "                edges.append({\n",
    "                    \"from\": str(ppid),\n",
    "                    \"to\":   str(pid),\n",
    "                    \"from_name\": pid_to_name[ppid],\n",
    "                    \"to_name\":   pid_to_name.get(pid, f\"pid_{pid}\"),\n",
    "                })\n",
    "                seen_edges.add(edge_key)\n",
    "\n",
    "    return {\"nodes\": nodes, \"edges\": edges}\n",
    "\n",
    "\n",
    "def extract_iocs(events: List[Dict[str, Any]], report: dict) -> Dict[str, List[str]]:\n",
    "    \"\"\"Collect concrete IOC values from de-duplicated events.\"\"\"\n",
    "    by_type: Dict[str, List[str]] = defaultdict(list)\n",
    "    for e in events:\n",
    "        by_type[e[\"type\"]].append(e[\"value\"])\n",
    "\n",
    "    behavior = report.get(\"behavior\", {})\n",
    "    summary  = behavior.get(\"summary\", {})\n",
    "    mutexes  = summary.get(\"mutexes\", [])\n",
    "\n",
    "    return {\n",
    "        \"domains\":          list(set(by_type[\"dns_query\"]))[:20],\n",
    "        \"ips\":              list(set(by_type[\"tcp_connect\"]))[:20],\n",
    "        \"http_uris\":        list(set(by_type[\"http_request\"]))[:20],\n",
    "        \"files_dropped\":    list(set(by_type[\"file_write\"]))[:20],\n",
    "        \"registry_writes\":  list(set(by_type[\"reg_write\"]))[:20],\n",
    "        \"mutexes\":          list(set(m for m in mutexes if isinstance(m, str)))[:20],\n",
    "    }\n",
    "\n",
    "\n",
    "def build_ir(filepath: str, sha256: str = \"\") -> Dict[str, Any]:\n",
    "    \"\"\"\n",
    "    Build the complete Behavior IR for a single CAPEv2 report file.\n",
    "\n",
    "    Returns IR dict with schema::\n",
    "\n",
    "        {\n",
    "          \"sha256\": str,\n",
    "          \"behaviors\": [{\"type\", \"evidence\", \"score\"}, ...],\n",
    "          \"iocs\": {\"domains\", \"ips\", \"http_uris\", \"files_dropped\",\n",
    "                   \"registry_writes\", \"mutexes\"},\n",
    "          \"process_graph\": {\"nodes\", \"edges\"}\n",
    "        }\n",
    "    \"\"\"\n",
    "    if not sha256:\n",
    "        sha256 = Path(filepath).stem\n",
    "\n",
    "    try:\n",
    "        with open(filepath, \"r\", encoding=\"utf-8\", errors=\"ignore\") as fh:\n",
    "            report = json.load(fh)\n",
    "    except (json.JSONDecodeError, IOError) as err:\n",
    "        return {\"sha256\": sha256, \"error\": str(err), \"behaviors\": [], \"iocs\": {}, \"process_graph\": {}}\n",
    "\n",
    "    # Step 1: normalize to typed events\n",
    "    events     = normalize_events(report)\n",
    "    # Step 2: remove duplicates\n",
    "    deduped    = deduplicate_events(events)\n",
    "    # Step 3: detect motifs\n",
    "    motifs     = detect_motifs(deduped)\n",
    "    # Step 4: extract IOCs\n",
    "    iocs       = extract_iocs(deduped, report)\n",
    "    # Step 5: build process graph\n",
    "    proc_graph = build_process_graph(report)\n",
    "\n",
    "    return {\n",
    "        \"sha256\":        sha256,\n",
    "        \"behaviors\":     motifs,\n",
    "        \"iocs\":          iocs,\n",
    "        \"process_graph\": proc_graph,\n",
    "    }\n",
    "\n",
    "\n",
    "# Demo on the first report\n",
    "if json_files:\n",
    "    ir = build_ir(json_files[0])\n",
    "    print(\"Sample IR:\")\n",
    "    print(json.dumps(ir, indent=2))"
   ]
  },
