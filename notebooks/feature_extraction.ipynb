    "#\n",
    "# Build a compact IR for each sample using the same parsed features\n",
    "# already loaded in this notebook.  This avoids re-reading JSON files\n",
    "# and keeps the section lightweight.\n",
    "# -----------------------------------------------------------\n",
    "\n",
    "import re as _re\n",
    "from pathlib import Path as _Path\n",
    "\n",
    "# ---- Behavior motif detection constants ----\n",
    "_INJECTION_APIS = {\n",
    "    \"WriteProcessMemory\", \"VirtualAllocEx\", \"CreateRemoteThread\",\n",
    "    \"NtWriteVirtualMemory\", \"NtCreateThreadEx\", \"RtlCreateUserThread\",\n",
    "    \"SetThreadContext\", \"QueueUserAPC\",\n",
    "}\n",
    "_HOOK_APIS = {\n",
    "    \"SetWindowsHookEx\", \"SetWindowsHookExA\", \"SetWindowsHookExW\",\n",
    "    \"GetAsyncKeyState\", \"GetKeyState\",\n",
    "}\n",
    "_RUN_KEY_PATTERNS = [\n",
    "    _re.compile(r\"\\\\(CurrentVersion\\\\Run|RunOnce|RunServices)\", _re.IGNORECASE),\n",
    "]\n",
    "_EXECUTABLE_EXTS = {\".exe\", \".dll\", \".bat\", \".ps1\", \".vbs\", \".scr\", \".com\", \".pif\"}\n",
    "\n",
    "\n",
    "def _detect_ir_motifs(features: dict) -> list:\n",
    "    \"\"\"Derive scored behavior motifs from pre-parsed feature dict.\"\"\"\n",
    "    api_calls = features.get(\"api_calls\", [])\n",
    "    files     = features.get(\"files\", [])        # list of (path, op)\n",
    "    registry  = features.get(\"registry\", [])     # list of (key, op)\n",
    "    domains   = features.get(\"domains\", [])\n",
    "    http_reqs = features.get(\"http_requests\", [])\n",
    "    commands  = features.get(\"executed_commands\", [])\n",
    "\n",
    "    motifs = []\n",
    "\n",
    "    # Persistence: Run key writes\n",
    "    run_keys = [\n",
    "        k for k, op in registry\n",
    "        if op == \"write\" and any(pat.search(k) for pat in _RUN_KEY_PATTERNS)\n",
    "    ]\n",
    "    if run_keys:\n",
    "        motifs.append({\n",
    "            \"type\": \"persistence_registry_runkey\",\n",
    "            \"evidence\": run_keys[:5],\n",
    "            \"score\": min(0.5 + 0.1 * len(run_keys), 1.0),\n",
    "        })\n",
    "\n",
    "    # Process injection APIs\n",
    "    inj = list({a for a in api_calls if a in _INJECTION_APIS})\n",
    "    if inj:\n",
    "        motifs.append({\n",
    "            \"type\": \"process_injection\",\n",
    "            \"evidence\": inj,\n",
    "            \"score\": round(min(0.3 * len(inj), 1.0), 2),\n",
    "        })\n",
    "\n",
    "    # File dropper (executable written)\n",
    "    dropped = [\n",
    "        f for f, op in files\n",
    "        if op == \"write\" and _Path(f).suffix.lower() in _EXECUTABLE_EXTS\n",
    "    ]\n",
    "    if dropped:\n",
    "        motifs.append({\n",
    "            \"type\": \"file_dropper\",\n",
    "            \"evidence\": dropped[:5],\n",
    "            \"score\": min(0.4 + 0.1 * len(dropped), 1.0),\n",
    "        })\n",
    "\n",
    "    # DNS C2 beacon\n",
    "    if domains:\n",
    "        motifs.append({\n",
    "            \"type\": \"dns_c2_beacon\",\n",
    "            \"evidence\": [f\"domain: {d}\" for d in domains[:5]],\n",
    "            \"score\": min(0.3 + 0.05 * len(domains), 1.0),\n",
    "        })\n",
    "\n",
    "    # HTTP C2\n",
    "    if http_reqs:\n",
    "        motifs.append({\n",
    "            \"type\": \"http_c2\",\n",
    "            \"evidence\": http_reqs[:5],\n",
    "            \"score\": min(0.4 + 0.05 * len(http_reqs), 1.0),\n",
    "        })\n",
    "\n",
    "    # Keylogger hook\n",
    "    hook = list({a for a in api_calls if a in _HOOK_APIS})\n",
    "    if hook:\n",
    "        motifs.append({\"type\": \"keylogger_hook\", \"evidence\": hook, \"score\": 0.75})\n",
    "\n",
    "    # Lateral movement\n",
    "    ips = features.get(\"ips\", [])\n",
    "    if ips and commands:\n",
    "        motifs.append({\n",
    "            \"type\": \"lateral_movement\",\n",
    "            \"evidence\": [f\"ip: {ip}\" for ip in ips[:3]],\n",
    "            \"score\": 0.65,\n",
    "        })\n",
    "\n",
    "    # Credential access\n",
    "    cred = [\n",
    "        k for k, op in registry\n",
    "        if _re.search(r\"(sam|security|lsass)\", k, _re.IGNORECASE)\n",
    "    ]\n",
    "    if cred:\n",
    "        motifs.append({\"type\": \"credential_access\", \"evidence\": cred[:5], \"score\": 0.80})\n",
    "\n",
    "    # Heavy registry activity\n",
    "    reg_writes = sum(1 for _, op in registry if op == \"write\")\n",
    "    if reg_writes >= 10:\n",
    "        motifs.append({\n",
    "            \"type\": \"heavy_registry_activity\",\n",
    "            \"evidence\": [f\"{reg_writes} registry writes\"],\n",
    "            \"score\": round(min(0.2 + 0.01 * reg_writes, 0.7), 2),\n",
    "        })\n",
    "\n",
    "    motifs.sort(key=lambda m: m[\"score\"], reverse=True)\n",
    "    return motifs\n",
    "\n",
    "\n",
    "def build_ir_from_features(report_hash: str, features: dict,\n",
    "                            family: str = \"unknown\", maltype: str = \"unknown\") -> dict:\n",
    "    \"\"\"\n",
    "    Build a compact Behavior IR from an already-parsed feature dict.\n",
    "\n",
    "    Returns:\n",
    "        {\n",
    "          \"sha256\": str,\n",
    "          \"family\": str,\n",
    "          \"type\": str,\n",
    "          \"behaviors\": [{\"type\", \"evidence\", \"score\"}, ...],\n",
    "          \"iocs\": {\"domains\", \"ips\", \"http_uris\", \"files_dropped\",\n",
    "                   \"registry_writes\", \"mutexes\"},\n",
    "          \"process_graph\": {\"nodes\": [], \"edges\": []}  # placeholder\n",
    "        }\n",
    "    \"\"\"\n",
    "    motifs = _detect_ir_motifs(features)\n",
    "\n",
    "    # IOCs\n",
    "    files_dropped = [\n",
    "        f for f, op in features.get(\"files\", [])\n",
    "        if op == \"write\" and _Path(f).suffix.lower() in _EXECUTABLE_EXTS\n",
    "    ]\n",
    "    reg_writes = [\n",
    "        k for k, op in features.get(\"registry\", []) if op == \"write\"\n",
    "    ]\n",
    "\n",
    "    iocs = {\n",
    "        \"domains\":          features.get(\"domains\", [])[:20],\n",
    "        \"ips\":              features.get(\"ips\", [])[:20],\n",
    "        \"http_uris\":        features.get(\"http_requests\", [])[:20],\n",
    "        \"files_dropped\":    list(set(files_dropped))[:20],\n",
    "        \"registry_writes\":  list(set(reg_writes))[:20],\n",
    "        \"mutexes\":          features.get(\"mutexes\", [])[:20],\n",
    "    }\n",
    "\n",
    "    return {\n",
    "        \"sha256\":        report_hash,\n",
    "        \"family\":        family,\n",
    "        \"type\":          maltype,\n",
    "        \"behaviors\":     motifs,\n",
    "        \"iocs\":          iocs,\n",
    "        \"process_graph\": {\"nodes\": [], \"edges\": []},  # full graph available in behavior_ir.ipynb\n",
    "    }\n",
    "\n",
    "\n",
    "# Build IR for all processed samples\n",
    "print(\"Building Behavior IR records from extracted features...\")\n",
    "ir_from_features = []\n",
    "for idx, (report_hash, features) in enumerate(zip(report_hashes, all_features)):\n",
    "    family  = hash_to_family.get(report_hash, \"unknown\")\n",
    "    maltype = hash_to_type.get(report_hash, \"unknown\")\n",
    "    ir = build_ir_from_features(report_hash, features, family=family, maltype=maltype)\n",
    "    ir_from_features.append(ir)\n",
    "\n",
    "print(f\"Built {len(ir_from_features)} IR records\")\n",
    "\n",
    "# Save alongside other processed outputs\n",
    "ir_out_path = PROCESSED_DIR / \"behavior_ir.json\"\n",
    "with open(ir_out_path, \"w\") as fh:\n",
    "    json.dump(ir_from_features, fh, indent=2)\n",
    "print(f\"Saved behavior_ir.json -> {ir_out_path}\")\n",
    "\n",
    "# Quick motif distribution\n",
    "from collections import Counter as _Counter\n",
    "motif_dist = _Counter(\n",
    "    m[\"type\"]\n",
    "    for ir in ir_from_features\n",
    "    for m in ir.get(\"behaviors\", [])\n",
    ")\n",
    "print(\"\\nTop behavior motifs across dataset:\")\n",
    "for motif, cnt in motif_dist.most_common(10):\n",
    "    print(f\"  {motif}: {cnt} samples ({100*cnt/len(ir_from_features):.1f}%)\")"
   ]
